{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aa-engine.dev/schemas/config_get_result.schema.json",
  "title": "ConfigGetResult",
  "type": "object",
  "required": ["ok", "project", "key", "source", "diagnostics", "duration_ms"],
  "properties": {
    "ok": { "type": "boolean" },
    "project": { "$ref": "#/$defs/project_path" },
    "key": { "type": "string", "minLength": 1 },
    "value": {},
    "value_type": {
      "type": "string",
      "enum": ["str", "int", "float", "bool", "list", "dict", "null"]
    },
    "source": {
      "type": "string"
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "duration_ms": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "project_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\\\).+$"
    },
    "project_path_or_empty": {
      "type": "string",
      "pattern": "^$|^(?!/)(?!.*\\.\\.)(?!.*\\\\).+$"
    },
    "span": {
      "type": "object",
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "message": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/project_path" },
        "span": { "$ref": "#/$defs/span" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
