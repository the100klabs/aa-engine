{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aa-engine.dev/schemas/scene_inspect_result.schema.json",
  "title": "SceneInspectResult",
  "type": "object",
  "required": ["ok", "scene", "kind", "entity_id", "diagnostics", "duration_ms"],
  "properties": {
    "ok": { "type": "boolean" },
    "scene": { "$ref": "#/$defs/project_path" },
    "kind": { "type": "string", "enum": ["scene", "prefab", "sector"] },
    "entity_id": { "type": "string", "minLength": 1 },
    "entity": { "$ref": "#/$defs/entity_detail" },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "duration_ms": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "project_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\\\).+$"
    },
    "vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "transform": {
      "type": "object",
      "properties": {
        "translation": { "$ref": "#/$defs/vec3" },
        "rotation_y_degrees": { "type": "number" },
        "rotation_euler": { "$ref": "#/$defs/vec3" },
        "scale": { "$ref": "#/$defs/vec3" }
      },
      "additionalProperties": false
    },
    "entity_detail": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "prefab": { "$ref": "#/$defs/project_path" },
        "layers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "transform": { "$ref": "#/$defs/transform" },
        "components": { "type": "object" },
        "children": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "message": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/project_path" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
