{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aa-engine.dev/schemas/scene_list_result.schema.json",
  "title": "SceneListResult",
  "type": "object",
  "required": ["ok", "scene", "kind", "entity_count", "entities", "diagnostics", "duration_ms"],
  "properties": {
    "ok": { "type": "boolean" },
    "scene": { "$ref": "#/$defs/project_path" },
    "kind": { "type": "string", "enum": ["scene", "prefab", "sector"] },
    "entity_count": { "type": "integer", "minimum": 0 },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity_summary" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "duration_ms": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "project_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\\\).+$"
    },
    "entity_summary": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "prefab": { "$ref": "#/$defs/project_path" },
        "layers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "component_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "message": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/project_path" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
