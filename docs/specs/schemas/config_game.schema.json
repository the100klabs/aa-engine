{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aa-engine.dev/schemas/config_game.schema.json",
  "title": "AaGameConfig",
  "type": "object",
  "required": ["gameplay", "teams"],
  "properties": {
    "gameplay": {
      "type": "object",
      "required": ["default_damage_scale", "respawn_delay_secs"],
      "properties": {
        "default_damage_scale": { "type": "number", "minimum": 0 },
        "respawn_delay_secs": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "teams": {
      "type": "object",
      "required": ["max_teams", "friendly_fire"],
      "properties": {
        "max_teams": { "type": "integer", "minimum": 1, "maximum": 255 },
        "friendly_fire": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
