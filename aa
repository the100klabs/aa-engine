#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
RUST_COMMANDS="check validate index playtest world scene eval profile"

if [[ $# -lt 1 ]]; then
  exec python3 "$REPO_ROOT/docs/specs/tools/aa_bootstrap.py"
fi

cmd="$1"
if [[ " $RUST_COMMANDS " == *" $cmd "* ]]; then
  exec cargo run -p aa_cli --quiet -- "$@"
fi

exec python3 "$REPO_ROOT/docs/specs/tools/aa_bootstrap.py" "$@"
