(
    schema_version: 1,
    id: "experience_boot",
    display_name: "Experience Boot",
    description: "ExperienceReady within startup budget.",
    duration_secs: 8.0,
    setup: (
        LoadExperience: "assets/experiences/demo.ron",
    ),
    assertions: [
        (
            name: "no_crash",
            check: (
                NoCrash: true,
            ),
        ),
    ],
    artifacts: ["log"],
)
