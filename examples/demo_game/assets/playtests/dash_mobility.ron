(
    schema_version: 1,
    id: "dash_mobility",
    display_name: "Dash Mobility",
    description: "Dash ability mobility check.",
    duration_secs: 10.0,
    setup: (
        LoadExperience: "assets/experiences/demo.ron",
    ),
    input_script: [
        (
            at_secs: 1.0,
            action: (
                ActivateAbility: (
                    ability: "assets/abilities/dash.ron",
                    player_id: 0,
                ),
            ),
        ),
    ],
    assertions: [
        (
            name: "no_crash",
            check: (
                NoCrash: true,
            ),
        ),
    ],
    artifacts: ["log"],
)
