(
    schema_version: 1,
    id: "streaming_budget_smoke",
    display_name: "Streaming Budget Smoke",
    description: "Sector load and hitch budgets within targets.",
    duration_secs: 30.0,
    setup: (
        LoadWorld: "assets/worlds/open_world_studio.ron",
    ),
    assertions: [
        (
            name: "no_crash",
            check: (
                NoCrash: true,
            ),
        ),
        (
            name: "sector_load_budget",
            check: (
                BudgetWithin: (
                    metric: "sector_load_p95_ms",
                    max: 400.0,
                ),
            ),
        ),
    ],
    artifacts: ["log", "trace"],
)
